# Development Example
# Copy to .env or your local shell for development only. Production values belong in
# the server/Pachim secret manager and must not be committed.

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000 # Public app URL used by the web app in development.
NEXT_PUBLIC_MARKETING_URL=http://localhost:3000 # Public marketing URL placeholder for local development.

# PostgreSQL
POSTGRES_HOST=localhost # PostgreSQL host for development.
POSTGRES_PORT=5432 # PostgreSQL port for development.
POSTGRES_DB=football_performance_platform # Development database name.
POSTGRES_USER=app_user # Development database user.
POSTGRES_PASSWORD=change-me-in-local-env # Sample password; replace in your local .env.
DATABASE_URL=postgresql://app_user:change-me-in-local-env@localhost:5432/football_performance_platform # Drizzle connection string.

# MinIO / S3-compatible object storage
S3_ENDPOINT=http://localhost:9000 # Local MinIO API endpoint.
S3_PUBLIC_ENDPOINT=http://localhost:9001 # Local MinIO console endpoint.
S3_REGION=local # Local development region placeholder.
S3_BUCKET=football-performance-platform-dev # Development object bucket.
S3_ACCESS_KEY_ID=minio-dev-access-key # Sample local access key; replace in your local .env.
S3_SECRET_ACCESS_KEY=minio-dev-secret-key # Sample local secret key; replace in your local .env.

# Mail testing
SMTP_HOST=localhost # Mail testing host.
SMTP_PORT=1025 # Mail testing SMTP port.
SMTP_FROM=no-reply@example.test # Development sender address.
