# Local dev default (SQLite). For production switch provider to "postgresql"
# in prisma/schema.prisma and set DATABASE_URL to your Postgres connection string.
DATABASE_URL="file:./dev.db"

# Generate a long random string, e.g. `openssl rand -base64 48`
JWT_SECRET="replace-with-a-long-random-secret"

# Public URLs used for cross-subdomain auth redirects.
NEXT_PUBLIC_MARKETING_URL="https://athvexa.com"
NEXT_PUBLIC_APP_URL="https://app.athvexa.com"

# Share login sessions across athvexa.com and app.athvexa.com in production.
SESSION_COOKIE_DOMAIN=".athvexa.com"
