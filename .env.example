# SQLite for local dev — switch to a Postgres connection string in production
# (see README) and update prisma/schema.prisma's datasource provider to match.
DATABASE_URL="file:./dev.db"

# The public URL this app is served from. Used to build invite links
# (https://athvexa.com/invite/{token}) and must NOT be left unset in
# production — see src/lib/invites.ts for the fallback behavior.
NEXT_PUBLIC_APP_URL="https://athvexa.com"
