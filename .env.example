# Local dev default (SQLite). For production switch provider to "postgresql"
# in prisma/schema.prisma and set DATABASE_URL to your Postgres connection string.
DATABASE_URL="file:./dev.db"

# Generate a long random string, e.g. `openssl rand -base64 48`
JWT_SECRET="replace-with-a-long-random-secret"

# Used to build invite links (e.g. https://app.athvexa.com)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
